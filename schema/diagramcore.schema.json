{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oleksii94/diagramcore/schema/diagramcore.schema.json",
  "title": "DiagramCore diagram (*.dc.yaml) v0",
  "type": "object",
  "required": ["diagram", "nodes", "links"],
  "additionalProperties": false,
  "properties": {
    "diagram": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string" },
        "audience": { "type": "string" },
        "version": { "type": "string" },
        "custom_types": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "shape": { "type": "string" },
                  "color": { "type": "string" },
                  "icon": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "links": {
      "type": "array",
      "items": { "$ref": "#/$defs/link" }
    },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/flow" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_]*$" },
        "type": {
          "type": "string",
          "enum": ["actor", "service", "storage", "queue", "external", "component"]
        },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "ai_context": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "details": { "type": "string" }
      }
    },
    "link": {
      "type": "object",
      "required": ["from", "to", "type"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["request", "call", "query", "event", "dataflow", "inherits", "contains"]
        },
        "label": { "type": "string" },
        "directed": { "type": "boolean" }
      }
    },
    "flow": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [
              { "$ref": "#/$defs/step" },
              { "$ref": "#/$defs/branchWrapper" }
            ]
          }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "branchWrapper": {
      "type": "object",
      "required": ["branch"],
      "additionalProperties": false,
      "properties": {
        "branch": { "$ref": "#/$defs/branch" }
      }
    },
    "branch": {
      "type": "object",
      "required": ["condition", "then"],
      "additionalProperties": false,
      "properties": {
        "condition": { "type": "string", "minLength": 1 },
        "then": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        },
        "else": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        }
      }
    }
  }
}
